generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  firebaseUid  String        @unique
  name         String?
  email        String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  categories   Category[]
  bills        Bill[]
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  limit     Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  description String
  amount      Decimal         @db.Decimal(14, 2)
  type        TransactionType
  category    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, category])
}

model Bill {
  id          String         @id @default(uuid())
  userId      String
  description String
  amount      Decimal        @db.Decimal(14, 2)
  dueDate     DateTime       @db.Date
  category    String         @db.VarChar(120)
  status      BillStatus     @default(pending)
  recurrence  BillRecurrence @default(none)
  paidAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, recurrence])
}

enum TransactionType {
  income
  expense
}

enum BillStatus {
  pending
  paid
  overdue
}

enum BillRecurrence {
  none
  weekly
  monthly
  yearly
}
